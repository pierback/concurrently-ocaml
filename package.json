{
  "name": "@pierback/concurrently-ml",
  "version": "0.0.13",
  "description": "OCaml 5 command runner targeting feature parity with npm concurrently",
  "bin": {
    "conc": "npm/bin/concurrently-ml.js",
    "concml": "npm/bin/concurrently-ml.js"
