{
  "name": "@pierback/concurrently-ml",
  "version": "0.0.14",
  "description": "Native OCaml CLI binary targeting feature parity with npm concurrently",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": "./index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "index.d.mts",
    "npm/bin/",
    "npm/lib/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "concurrently": "npm/bin/concurrently-ml.js",
    "conc": "npm/bin/concurrently-ml.js",
    "concml": "npm/bin/concurrently-ml.js"
  },
  "scripts": {
    "setup:opam": "sh scripts/dev/setup-opam-switch.sh",
    "build": "opam exec -- dune build @install",
    "test": "opam exec -- dune runtest",
    "compile": "opam exec -- dune build bin/main.exe",
    "package:platform": "node scripts/ci/package-platform.js",
    "smoke:npm-install": "node scripts/ci/smoke-npm-install.js",
    "smoke:npm-install:host": "node scripts/ci/smoke-npm-install-host.js",
    "smoke:windows-native": "node scripts/ci/smoke-windows-native.js",
    "audit:npm-api": "node scripts/ci/audit-npm-api-surface.js",
    "compat:concurrently": "node scripts/ci/compat-concurrently.js",
    "perf:concurrently": "node scripts/ci/perf-concurrently.js"
  },
  "keywords": [
    "concurrently",
    "ocaml",
    "cli",
    "process",
    "eio"
  ],
  "author": "Franz Pieringer",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "rxjs": "7.8.2"
  },
  "optionalDependencies": {
    "@pierback/concurrently-ml-darwin-arm64": "0.0.14",
    "@pierback/concurrently-ml-darwin-x64": "0.0.14",
    "@pierback/concurrently-ml-linux-arm64-gnu": "0.0.14",
    "@pierback/concurrently-ml-linux-arm64-musl": "0.0.14",
    "@pierback/concurrently-ml-linux-x64-gnu": "0.0.14",
    "@pierback/concurrently-ml-linux-x64-musl": "0.0.14",
    "@pierback/concurrently-ml-win32-x64": "0.0.14"
  },
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierback/concurrently-ocaml.git"
  },
  "bugs": {
    "url": "https://github.com/pierback/concurrently-ocaml/issues"
  },
  "homepage": "https://github.com/pierback/concurrently-ocaml#readme"
}
